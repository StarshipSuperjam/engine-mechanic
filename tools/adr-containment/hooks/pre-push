#!/bin/sh
# Local pre-push guardrail for the ENGINE-TEMPLATE checkout (engine-mechanic ADR containment).
#
# Scans exactly what this push would publish — each pushed ref's new commits — for
# engine-mechanic's deployment-local decision-record references (product ADR numbers,
# retired planning D-numbers, the retired workspace name). Git hands the pushed refs on
# stdin; scanning the checked-out HEAD instead would miss a push of another branch.
#
# Install (from the engine-template checkout):
#   cp <engine-mechanic>/tools/adr-containment/hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
# This copy in engine-mechanic is the reviewed source of what runs; the installed hook is
# local and uncommitted, bypassable with --no-verify, and absent on other clones — a bonus
# layer, never the wall. Rule: engine-mechanic .engine/contracts/instance/
# engine-mechanic-eADR-0001-adr-containment-guardrail.md
CHECK=/Users/shanekidd/Developer/engine-mechanic/tools/adr-containment/check.py
if [ ! -f "$CHECK" ]; then
  echo "pre-push: adr-containment checker not found at $CHECK (not merged yet?) — push allowed, scan SKIPPED" >&2
  exit 0
fi
ZERO=0000000000000000000000000000000000000000
status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue   # deleting a remote ref publishes nothing new
  if [ "$remote_sha" = "$ZERO" ]; then
    # brand-new remote ref: scan against the upstream default (or everything if absent)
    if base=$(git merge-base origin/main "$local_sha" 2>/dev/null); then :; else base=""; fi
  else
    base="$remote_sha"
  fi
  if [ -z "$base" ]; then
    echo "pre-push: no scan base for $local_ref — push allowed, scan SKIPPED for this ref" >&2
    continue
  fi
  if ! python3 "$CHECK" outgoing "$base" "$local_sha"; then
    status=1
  fi
done
if [ "$status" -ne 0 ]; then
  echo "pre-push: blocked — outgoing work references engine-mechanic's decision records (see above)" >&2
fi
exit "$status"
